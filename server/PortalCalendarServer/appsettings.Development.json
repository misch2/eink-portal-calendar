{
    "Logging": {
        "LogLevel": {
            "PortalCalendarServer": "Debug"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Data Source={ContentRootPath}/../localdata/database/calendar.db",
        "SessionConnection": "Data Source={ContentRootPath}/../localdata/database/sessions.db"
    },
    "Paths": {
        "DatabaseFiles": "{ContentRootPath}/../localdata/database",
        "GeneratedImages": "{ContentRootPath}/../localdata/generated_images",
        "DataProtectionKeys": "{ContentRootPath}/../localdata/data-protection-keys"
    },
    "URLs": {
        "BaseURL": "https://localhost:7199/"
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://0.0.0.0:5252"
            },
            "Https": {
                "Url": "https://127.0.0.1:7199"
            }
        }
    },
    "Auth": {
        "CookieName": "PortalCalendarAuthDev"
    },
    "BackgroundJobs": {
        "BitmapGeneration": {
            "StartupDelayMinutes": 60,
            "IntervalMinutes": 15
        }
    },
    "Deployment": {
        "Version": "dev"
    }
}
