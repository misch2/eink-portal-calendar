@* Partial view for wakeup info *@
@using PortalCalendarServer.Models.DatabaseEntities
@using PortalCalendarServer.Services
@model Display
@inject IDisplayService displayService

@{
    var wakeupInfo = displayService.GetNextWakeupTime(Model);
    var nextWakeup = wakeupInfo.NextWakeup;

    var dateCulture = displayService.GetDateCultureInfo(Model);
    var tz = displayService.GetTimeZoneInfo(Model);

}

@if (displayService.GetConfigBool(Model, "theme_config_status_wakeupinfo"))
{
    @* Date rendered *@
    <iconify-icon icon="material-symbols:screenshot-monitor-outline-rounded" style="vertical-align: text-bottom"></iconify-icon>

    @DateTime.UtcNow.ToString("t", dateCulture)

    <iconify-icon icon="material-symbols:arrow-right-alt" style="vertical-align: text-bottom"></iconify-icon>

    @* Next refresh *@
    <iconify-icon icon="material-symbols:refresh" style="vertical-align: text-bottom"></iconify-icon>

    @TimeZoneInfo.ConvertTimeFromUtc(nextWakeup, tz).ToString("t", dateCulture)<text>.</text>
}