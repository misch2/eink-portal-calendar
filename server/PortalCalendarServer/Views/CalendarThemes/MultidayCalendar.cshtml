@model PortalCalendarServer.Services.PageViewModel
@using System.Globalization
@using PortalCalendarServer.Models.DatabaseEntities
@using PortalCalendarServer.Services
@using PortalCalendarServer.Services.PageGeneratorComponents
@inject IDisplayService displayService
@{
    Layout = null;

    var dateCulture = displayService.GetDateCultureInfo(Model.Display);
    var tz = displayService.GetTimeZoneInfo(Model.Display);

    var wakeupInfo = displayService.GetNextWakeupTime(Model.Display);
    var nextWakeup = wakeupInfo.NextWakeup;
    var sleepInSeconds = wakeupInfo.SleepInSeconds;
    var schedule = wakeupInfo.Schedule;

    var calendarComponent = Model.Calendar;
    var calendar = calendarComponent?.GetDetails(Model.Display, Model.Date);
    var nearestEvents = calendar?.NearestEvents;

    // Helper class for grouping events
    var eventBlocks = new[]
    {
        new {
            Id = "2days",
            Title = "Dnes a zítra",
            Class = "calendar-event-block-today",
            Condition = (Func<CalendarEvent, bool>)(evt => {
                var deltaDays = (evt.StartTime.Date - Model.Date.Date).Days;
                var deltaHours = (evt.StartTime - Model.Date).TotalHours;
                return deltaHours >= 0 && deltaDays <= 1;
            })
        },
        new {
            Id = "week",
            Title = "Nejbližších 7 dní",
            Class = "calendar-event-block-week",
            Condition = (Func<CalendarEvent, bool>)(evt => {
                var deltaDays = (evt.StartTime.Date - Model.Date.Date).Days;
                return deltaDays > 1 && deltaDays <= 7;
            })
        },
        new {
            Id = "rest",
            Title = "Pozdější události",
            Class = "calendar-event-block-rest",
            Condition = (Func<CalendarEvent, bool>)(evt => {
                var deltaDays = (evt.StartTime.Date - Model.Date.Date).Days;
                return deltaDays > 7;
            })
        }
    };
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Calendar - Multiday</title>

    @* Icon library *@
    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@1.0.7/dist/iconify-icon.min.js"></script>

    @* Stylesheets *@
    <link rel="stylesheet" href="/css/calendar_themes/multiday_calendar.css" asp-append-version="true" />

    @* EPD Colors *@
    @await Html.PartialAsync("Includes/_EpdColors.cshtml", Model.CssColors)
</head>

@{
            int width = Model.Display.VirtualWidth();
            int height = Model.Display.VirtualHeight();
}
<body style="width: @(width)px; height: @(height)px;">
    <div id="visible-area">

        <h3 id="calendar-title">
            @displayService.GetConfig(Model.Display, "display_title")
        </h3>

        <div class="calendar-container">
            @{
                var lastTitle = "";
            }
            @foreach (var block in eventBlocks)
            {
                var eventsForBlock = nearestEvents.Where(block.Condition).ToList();

                if (eventsForBlock.Any())
                {
                    <div class="calendar-event-block @block.Class">
                        <div class="calendar-event-block-title">@block.Title</div>
                        @{
                            lastTitle = "";
                        }
                        <div class="calendar-event-block-content">
                            @foreach (var evt in eventsForBlock)
                            {
                                var dt = evt.StartTime;
                                var deltaDays = (dt.Date - Model.Date.Date).Days;
                                var dt_local = TimeZoneInfo.ConvertTimeFromUtc(dt, tz);

                                var dayDescription = dateCulture.DateTimeFormat.GetDayName(dt_local.DayOfWeek);
                                var title = $"{dayDescription}, {dt_local:d. M. yyyy}";

                                if (deltaDays > 0)
                                {
                                    title += $" (+{deltaDays})";
                                }

                                if (title != lastTitle)
                                {
                                    lastTitle = title;
                                    <div class="calendar-day-title">
                                        @title
                                    </div>
                                }

                                <div class="calendar-event">
                                    @if (evt.IsRecurrent)
                                    {
                                        <text>?</text>
                                    }
                                    @if (evt.AllDay)
                                    {
                                        @evt.Summary
                                        <!-- (celý den) -->
                                    }
                                    else
                                    {
                                        @dt_local.ToString("t", dateCulture)
                                        <text> </text>
                                        @evt.Summary
                                        @if (evt.DurationHours.HasValue)
                                        {
                                            <text> (~@((int)(evt.DurationHours.Value + 0.5)) hod.)</text>
                                        }
                                    }
                                </div>
                            }
                        </div>  @* class="calendar-event-block-content" *@
                    </div>  @* class="calendar-event-block-..." *@
                }
            }
        </div>

        <div id="bottom-row">
            <div id="bottom-signature">
                @await Html.PartialAsync("~/Views/CalendarThemes/Includes/_WakeupInfo.cshtml", Model.Display)
            </div>
            <div id="battery-status">
                @await Html.PartialAsync("~/Views/CalendarThemes/Includes/_BatteryStatusIcon.cshtml", Model.Display)
            </div>
        </div>
    </div>
    <script>
        document.fonts.ready.then(function () {
            const container = document.querySelector(".calendar-container");

            const getContainerBottom = () => container.getBoundingClientRect().bottom;

            const allElements = Array.from(container.querySelectorAll(
                ".calendar-event-block-title, .calendar-day-title, .calendar-event"
            ));

            // Phase 1: hide all elements that overflow
            let firstHidden = null;
            for (const el of allElements) {
                const elBottom = el.getBoundingClientRect().bottom;
                if (elBottom > getContainerBottom()) {
                    el.style.display = "none";
                    if (!firstHidden) firstHidden = el;
                }
            }

            if (!firstHidden) return;

            // Phase 2: insert indicator before the first hidden element
            const indicator = document.createElement("div");
            indicator.id = "overflow-indicator";
            indicator.textContent = "…";
            firstHidden.parentNode.insertBefore(indicator, firstHidden);

            // Phase 3: if the indicator itself overflows, keep hiding preceding
            // visible elements until the indicator fits (or nothing remains)
            const visibleElements = allElements.filter(el => el.style.display !== "none");
            let i = visibleElements.length - 1;
            while (indicator.getBoundingClientRect().bottom > getContainerBottom() && i >= 0) {
                visibleElements[i].style.display = "none";
                i--;
            }

            // Phase 4: if indicator still doesn't fit, remove it entirely
            if (indicator.getBoundingClientRect().bottom > getContainerBottom()) {
                indicator.remove();
            }
        });
    </script>
</body>
</html>
