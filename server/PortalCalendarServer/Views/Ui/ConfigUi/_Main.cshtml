@model Display
@using PortalCalendarServer.Models.DatabaseEntities
@using PortalCalendarServer.Models.POCOs
@using PortalCalendarServer.Services
@inject IDisplayService DisplayService

@if (!Model.IsDefault())
{
    <fieldset class="row mb-3">
        <legend class="w-auto">Name (title)</legend>
        <div class="col-md-12">
            <input id="display_name" name="display_name" type="text" class="form-control" value="@Model.Name">
        </div>
    </fieldset>

    <fieldset class="row mb-4">
        <legend class="w-auto">Theme</legend>
        @{
            var themes = (List<Theme>)ViewData["Themes"]!;
        }
        <div class="col-md-12">
            <select id="theme_id" name="theme_id" class="form-select">
                <option value=""></option>
                @foreach (var theme in themes)
                {
                    <option value="@theme.Id"
                            data-has-config="@theme.HasCustomConfig.ToString().ToLower()"
                            selected="@(Model.ThemeId == theme.Id)">
                        @theme.DisplayName
                    </option>
                }
            </select>
        </div>

        <div class="col-md-12 mt-3">
            <div class="card border-start border-primary border-3 bg-light">
                <div class="card-body">
                    <h6 class="card-subtitle mb-3 text-muted">
                        <i class="bi bi-gear"></i> Theme-specific Settings
                    </h6>
                    <div id="theme-customization" class="row">
                        <div class="col-12">
                            <small>Select a theme above to see available customization options</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </fieldset>
}

<fieldset class="row mb-3">
    <legend class="w-auto">Location and locale</legend>
    <div class="form-group row">
        @await Html.PartialAsync("_ConfigTextInput", new ConfigInputModel
        {
            Display = Model, Key = "lat", Label = "Latitude (+N/-S)", ColClass = "col-md-4"
        })
        @await Html.PartialAsync("_ConfigTextInput", new ConfigInputModel
        {
            Display = Model, Key = "lon", Label = "Longitude (+E/-W)", ColClass = "col-md-4"
        })
        @await Html.PartialAsync("_ConfigTextInput", new ConfigInputModel
        {
            Display = Model, Key = "alt", Label = "Altitude (m)", ColClass = "col-md-4"
        })
    </div>
    <div class="form-group row mt-2">
        @await Html.PartialAsync("_ConfigTextInput", new ConfigInputModel
        {
            Display = Model, Key = "timezone", Label = "Time Zone (format: \"UTC\", \"Europe/Prague\" etc.)",
            ColClass = "col-md-4"
        })
        @await Html.PartialAsync("_ConfigTextInput", new ConfigInputModel
        {
            Display = Model, Key = "date_culture", Label = "Date style (format: \"en-US\", \"cs-CZ\" etc.)",
            ColClass = "col-md-4"
        })
    </div>
</fieldset>
