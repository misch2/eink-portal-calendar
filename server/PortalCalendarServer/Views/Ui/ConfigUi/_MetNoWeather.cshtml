@model PortalCalendarServer.Models.DatabaseEntities.Display
@using PortalCalendarServer.Models.POCOs

@{
    ViewData["IntegrationName"] = "metnoweather";
}

<fieldset class="row mb-3" id="@(ViewData["IntegrationName"])_fieldset">
    @await Html.PartialAsync("ConfigUi/_IntegrationToggle", Model, ViewData)

    @await Html.PartialAsync("_ConfigTextInput", new ConfigInputModel
    {
        Display = Model, Key = "metnoweather_granularity_hours",
        Label = "Aggregate forecast by how many hours",
        ColClass = "col-md-4", MarginClass = "mt-3"
    })
</fieldset>
