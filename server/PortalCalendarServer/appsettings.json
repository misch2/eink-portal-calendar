{
    "Logging": {
        "LogLevel": {
            "Default": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Data Source={LocalAppDataPath}/database/calendar.db",
        "SessionConnection": "Data Source={LocalAppDataPath}/database/sessions.db"
    },
    "Paths": {
        "DatabaseFiles": "{LocalAppDataPath}/database",
        "GeneratedImages": "{LocalAppDataPath}/generated_images",
        "DataProtectionKeys": "{LocalAppDataPath}/data-protection-keys"
    },
    "AllowedHosts": "*",
    "Auth": {
        "CookieName": "PortalCalendarAuth"
    },
    "BackgroundJobs": {
        "BitmapGeneration": {
            "IntervalMinutes": 15
        },
        "CacheCleanup": {
            "StartupDelayMinutes": 5,
            "IntervalMinutes": 5
        },
        "MissedConnections": {
            "StartupDelayMinutes": 5,
            "IntervalMinutes": 5
        }
    },
    "Deployment": {
        "Version": "{DeployedVersion}"
    }
}
